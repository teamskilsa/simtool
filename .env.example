# Agent gateway port (default: 9050)
NEXT_PUBLIC_AGENT_GATEWAY_PORT=9050

# Agent port on remote systems (default: 9050)
AGENT_PORT=9050

# Remote deployment base directory (default: simtool/version_1)
REMOTE_BASE=simtool/version_1

# Path to agent bundle (default: <project_root>/agent/dist/server.js)
# AGENT_BUNDLE_PATH=/path/to/agent/dist/server.js

# Execution server URL (default: http://localhost:3001)
# NEXT_PUBLIC_EXECUTION_SERVER_URL=http://localhost:3001
