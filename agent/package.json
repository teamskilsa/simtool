{
  "name": "pro1_1-target-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Single-file agent deployed to each managed system; exposes /api/health, /api/stats, /api/nodes/* on port 9050",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/server.js --minify",
    "start": "node dist/server.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  }
}
